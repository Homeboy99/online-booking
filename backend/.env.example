FIREBASE_CONFIG={"type":"service_account","project_id":"your-project-id"}

ZENOPAY_API_KEY=your_zenopay_api_key
ZENOPAY_ACCOUNT_ID=your_zenopay_account_id
ZENOPAY_SECRET_KEY=your_zenopay_secret_key
ZENOPAY_BASE_URL=https://api.zeno.africa

# After Render creates the service, use your real Render URL.
# Use the same token value as ZENOPAY_WEBHOOK_SECRET.
ZENOPAY_WEBHOOK_URL=https://online-booking-backend.onrender.com/zenopay-webhook?token=your_webhook_secret
ZENOPAY_WEBHOOK_SECRET=your_webhook_secret

# Optional. Leave blank for mobile apps. Add web origins if you deploy Flutter web.
ALLOWED_ORIGINS=

# Local development only. Render provides PORT automatically.
PORT=3000
